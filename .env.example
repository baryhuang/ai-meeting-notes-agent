TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Drive watcher / rclone config
RCLONE_REMOTE=gdrive
GDRIVE_FOLDER=VoiceMemos
LOCAL_INBOX_DIR=/srv/transcribe/inbox
