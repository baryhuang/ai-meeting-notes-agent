# AssemblyAI API key (required)
ASSEMBLY_API_KEY=your_assemblyai_key_here

# Telegram Bot (required for telegram_bot.py)
# Get from @BotFather on Telegram: send /newbot and follow the steps
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# AI Summarization (optional — without this, full transcripts are sent directly)
# Works with any OpenAI-compatible API: OpenAI, OpenRouter, etc.
OPENAI_API_KEY=your_openai_api_key
# OPENAI_BASE_URL=https://api.openai.com/v1     # default; change for OpenRouter, etc.
# OPENAI_MODEL=gpt-4o-mini                       # default model for summarization

# Drive watcher / rclone config
RCLONE_REMOTE=gdrive
GDRIVE_FOLDER=VoiceMemos
LOCAL_INBOX_DIR=/srv/transcribe/inbox
